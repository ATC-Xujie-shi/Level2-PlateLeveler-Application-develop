                            <Label  Content=" "/>
                            <Button x:Name="btnRefresh" Content="{Binding Path=btnRefresh, Mode=OneWay, Source={StaticResource Resources}}" Click="btnRefresh_Click"  />
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Label  Content="               " Height="31"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Label  Content=" "/>
                            <RadioButton x:Name="rbPreview" Content="{Binding Path=rbPreview, Mode=OneWay, Source={StaticResource Resources}}" IsChecked="True" Checked="rbPreview_Checked" />
