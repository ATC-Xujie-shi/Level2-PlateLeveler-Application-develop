<Page x:Class="Level2.PlateLeveler.Client.pageLineState"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ig="http://schemas.infragistics.com/xaml"
    xmlns:Custom="http://infragistics.com/DataPresenter"
    xmlns:my="clr-namespace:Level2.PlateLeveler.Client"
    xmlns:igEditors="http://infragistics.com/Editors"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:type="clr-namespace:Level2.PlateLeveler.DataTypes;assembly=Level2.PlateLeveler.DataTypes"
	x:Name="pageLS"
    mc:Ignorable="d"
    d:DesignHeight="1000" d:DesignWidth="1920" >

    <Page.Resources>
        <CollectionViewSource x:Name="LineStateReportSource" x:Key="LineStateDataViewSource" d:DesignSource="{d:DesignInstance {x:Type type:LineState}, CreateList=True}"/>
        <Custom:FieldSettings  AllowRecordFiltering="True"  EditorStyle="{DynamicResource XamGridEditorStyle}" AllowEdit="False" x:Key="StandardColumn"/>
        <Custom:FieldSettings  AllowRecordFiltering="True"  EditorStyle="{DynamicResource XamGridTimeEditorStyle}" AllowEdit="False" x:Key="DateTimeColumn"/>
    </Page.Resources>
    <Page.Background>
        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="White" Offset="0.007"/>
            <GradientStop Color="White" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>
    <Grid>
        <Grid ShowGridLines="false" Margin="8,8,8,0" >
            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
            </Grid.RowDefinitions>
            <Grid  Margin="10"  Grid.Row="0" ShowGridLines="false" IsEnabled="True" Background="{x:Null}">
            <StackPanel Orientation="Horizontal">
               <StackPanel Orientation="Vertical">
                  <Label x:Name="lblFrom" Content="{Binding Path=From, Mode=OneWay, Source={StaticResource Resources}}" Margin="5"/>
                  <Label x:Name="lblTo" Content="{Binding Path=To, Mode=OneWay, Source={StaticResource Resources}}" Margin="5"/>
               </StackPanel>
               <StackPanel Orientation="Vertical">
                  <DatePicker x:Name="dtFrom" IsDropDownOpen="False" SelectedDateChanged="dtFrom_SelectedDateChanged" Width="Auto"  Margin="5"/>
                  <DatePicker x:Name="dtTo" IsDropDownOpen="False" SelectedDateChanged="dtTo_SelectedDateChanged" Width="Auto"  Margin="5"/>
               </StackPanel>
               <StackPanel Orientation="Vertical" Width="20"></StackPanel>
               <StackPanel Orientation="Vertical">
                  <Label x:Name="lblState" Content="{Binding Path=State, Mode=OneWay, Source={StaticResource Resources}}" HorizontalContentAlignment="Center"/>
                  <ComboBox x:Name="cboState" HorizontalAlignment="Left"   IsEnabled="True" SelectionChanged="cboState_SelectionChanged" Width="150">
                     <ComboBoxItem x:Name="cbItem0" Content="{Binding Path=Item0, Mode=OneWay, Source={StaticResource Resources}}" Tag="100"/>
                     <ComboBoxItem x:Name="cbItem1" Content="{Binding Path=Item1, Mode=OneWay, Source={StaticResource Resources}}" Tag="0"/>
                     <ComboBoxItem x:Name="cbItem2" Content="{Binding Path=Item2, Mode=OneWay, Source={StaticResource Resources}}" Tag="1"/>
                     <ComboBoxItem x:Name="cbItem3" Content="{Binding Path=Item3, Mode=OneWay, Source={StaticResource Resources}}" Tag="2"/>
                     <ComboBoxItem x:Name="cbItem4" Content="{Binding Path=Item4, Mode=OneWay, Source={StaticResource Resources}}" Tag="3"/>
                     <ComboBoxItem x:Name="cbItem5" Content="{Binding Path=Item5, Mode=OneWay, Source={StaticResource Resources}}" Tag="4"/>
                     <ComboBoxItem x:Name="cbItem6" Content="{Binding Path=Item6, Mode=OneWay, Source={StaticResource Resources}}" Tag="30"/>
                     <ComboBoxItem x:Name="cbItem7" Content="{Binding Path=Item7, Mode=OneWay, Source={StaticResource Resources}}" Tag="31"/>
                     <ComboBoxItem x:Name="cbItem8" Content="{Binding Path=Item8, Mode=OneWay, Source={StaticResource Resources}}" Tag="32"/>
                  </ComboBox>
               </StackPanel>
               <StackPanel Width="20"></StackPanel>
               <StackPanel Orientation="Vertical">
                  <RadioButton x:Name="rbPreview" Content="{Binding Path=rbPreview, Mode=OneWay, Source={StaticResource Resources}}" IsChecked="True" Checked="rbPreview_Checked" Margin="5"/>
                  <RadioButton x:Name="rbPrint" Content="{Binding Path=rbPrint, Mode=OneWay, Source={StaticResource Resources}}" Checked="rbPrint_Checked" Margin="5"/>
                  <RadioButton x:Name="rbExport" Content="{Binding Path=rbExport, Mode=OneWay, Source={StaticResource Resources}}" Checked="rbExport_Checked" Margin="5"/>
               </StackPanel>
               <StackPanel Orientation="Vertical" Width="20"></StackPanel>
               <StackPanel Orientation="Vertical">
                  <Button x:Name="btnLineState" Margin="7"  Content="{Binding Path=LineState, Mode=OneWay, Source={StaticResource Resources}}"  Click="btnReport_Click" IsEnabled="False" Width="150"/>
                  <Button x:Name="btnRefresh" Margin="7"  Content="{Binding Path=btnRefresh, Mode=OneWay, Source={StaticResource Resources}}" Click="btnRefresh_Click"  />
               </StackPanel>
            </StackPanel>
            <!--<StackPanel Orientation="Horizontal" Background="{x:Null}">
