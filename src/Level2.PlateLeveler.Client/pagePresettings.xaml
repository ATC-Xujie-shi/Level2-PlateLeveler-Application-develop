<Page x:Class="Level2.PlateLeveler.Client.pagePresettings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ig="http://schemas.infragistics.com/xaml"
    xmlns:Custom="http://infragistics.com/DataPresenter"
    xmlns:my="clr-namespace:Level2.PlateLeveler.Client"
    xmlns:igEditors="http://infragistics.com/Editors"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:type="clr-namespace:Level2.PlateLeveler.DataTypes;assembly=Level2.PlateLeveler.DataTypes"
	x:Name="Presetting"
    mc:Ignorable="d"
    d:DesignHeight="1000" d:DesignWidth="1920" >

    <Page.Resources>
        <CollectionViewSource x:Name="PreSettingsSource" x:Key="PreSettingsDataViewSource" d:DesignSource="{d:DesignInstance {x:Type type:PreSetting}, CreateList=True}"/>
        <CollectionViewSource x:Key="PreSettingsControlDataViewSource" d:DesignSource="{d:DesignInstance {x:Type type:PreSetting}, CreateList=True}"/>
        <CollectionViewSource x:Key="LimitViewSource" d:DesignSource="{d:DesignInstance {x:Type type:Limitation}, CreateList=True}"/>
    </Page.Resources>
    <Page.Background>
        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
         <GradientStop Color="White" Offset="0.007"/>
            <GradientStop Color="White" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>
    <Grid Visibility="Visible" ShowGridLines="false"  DataContext="{StaticResource PreSettingsControlDataViewSource}">
        <Grid ShowGridLines="false" Margin="8,8,8,0" >
            <Grid.RowDefinitions>
                <RowDefinition Height="150"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
            </Grid.RowDefinitions>
            <Grid  Margin="10"  Grid.Row="0" ShowGridLines="false" IsEnabled="True" Background="{x:Null}">
                <StackPanel Orientation="Horizontal" Background="{x:Null}">
                    <StackPanel Orientation="Vertical">
                        <Label x:Name="lblMaterialID" Content="{Binding Path=lblSteelgrade, Mode=OneWay, Source={StaticResource Resources}}" Margin="1" Height="30"/>
                  <Label x:Name="lblCassetteNo" Content="{Binding Path=lblCassetteNo, Mode=OneWay, Source={StaticResource Resources}}" Margin="1" Height="30"/>
                  <Label x:Name="lblStartRangeThickness" Content="{Binding Path=lblStartRangeThickness, Mode=OneWay, Source={StaticResource Resources}}" Margin="1" Height="30"/>
                  <Label x:Name="lblEndRangeThickness" Content="{Binding Path=lblEndRangeThickness, Mode=OneWay, Source={StaticResource Resources}}" Margin="1" Height="30"/>

                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                  <TextBox Margin="1" Height="30" x:Name="txtMaterialID" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MaterialID, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Margin="1" Height="30" x:Name="txtCassetteNo" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding CassetteNo, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Margin="1" Height="30" x:Name="txtStartRangeThickness" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding StartRangeThickness, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Margin="1" Height="30" x:Name="txtEndRangeThickness" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding EndRangeThickness, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Width="20">
                    </StackPanel>
               <StackPanel Orientation="Vertical">
                  <Label x:Name="lblStartRangeWidth" Content="{Binding Path=lblStartRangeWidth, Mode=OneWay, Source={StaticResource Resources}}" Margin="1" Height="30"/>
                  <Label x:Name="lblEndRangeWidth" Content="{Binding Path=lblEndRangeWidth, Mode=OneWay, Source={StaticResource Resources}}" Margin="1" Height="30"/>
                  <Label x:Name="lblCorrPlastification"  Content="{Binding Path=lblCorrPlastification, Mode=OneWay, Source={StaticResource Resources}}" Margin="1" Height="30"/>
                  <Label x:Name="lblCenterHeightBending"  Content="{Binding Path=lblCenterHeightBending, Mode=OneWay, Source={StaticResource Resources}}" Margin="1" Height="30"/>
               </StackPanel>
               <StackPanel Orientation="Vertical">
                  <TextBox Margin="1" Height="30" x:Name="txtStartRangeWidth" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding StartRangeWidth, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Margin="1" Height="30" x:Name="txtEndRangeWidth" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding EndRangeWidth, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Margin="1" Height="30" x:Name="txtCorrPlastification" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding CorrPlastification, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Margin="1" Height="30" x:Name="txtCenterHeightBending" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding CenterHeightBending, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
               </StackPanel>
               <StackPanel Orientation="Vertical" Width="20">
               </StackPanel>
               <StackPanel Orientation="Vertical">
                  <Label x:Name="lblCurveProfile"  Content="{Binding Path=lblCurveProfile, Mode=OneWay, Source={StaticResource Resources}}" Margin="1" Height="30"/>
                  <Label x:Name="lblTiltLeft"  Content="{Binding Path=lblTiltLeft, Mode=OneWay, Source={StaticResource Resources}}" Margin="1" Height="30"/>
                  <Label x:Name="lblTiltRight"  Content="{Binding Path=lblTiltRight, Mode=OneWay, Source={StaticResource Resources}}" Margin="1" Height="30"/>
                  <Label Content="{Binding Path=Enable, Mode=OneWay, Source={StaticResource Resources}}" Margin="2" Height="30"/>

                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                  <TextBox Margin="1" Height="30" x:Name="txtCurveProfile" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding CurveProfile, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Margin="1" Height="30" x:Name="txtTiltLeft" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding TiltingLeft, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Margin="1" Height="30" x:Name="txtTiltRight" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding TiltingRight, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                        <CheckBox x:Name="chkEnable" VerticalAlignment="Center" Margin="1 10" VerticalContentAlignment="Center" IsChecked="{Binding Enable, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False" />
               </StackPanel>
                    <StackPanel Orientation="Vertical" Width="50">
                    </StackPanel>
                    <StackPanel Orientation="Vertical">

                  <Button x:Name="btnCreate" Content="{Binding Path=btnCreate, Mode=OneWay, Source={StaticResource Resources}}" Width="100" Margin="5" Height="30" Click="btnCreate_Click" />
                  <Button x:Name="btnEdit" Content="{Binding Path=btnEdit, Mode=OneWay, Source={StaticResource Resources}}" Width="100" Margin="5" Height="30" IsEnabled="False" Click="btnEdit_Click" />
                  <Button x:Name="btnSave" Content="{Binding Path=btnSave, Mode=OneWay, Source={StaticResource Resources}}" Width="100" Margin="5" Height="30" IsEnabled="False" Click="btnSave_Click" />

               </StackPanel>
               <StackPanel>
                  <Button x:Name="btnCopy" Content="{Binding Path=btnCopy, Mode=OneWay, Source={StaticResource Resources}}" Width="100" Margin="5" Height="30" IsEnabled="False" Click="btnCopy_Click" />
                  <Button x:Name="btnDelete" Content="{Binding Path=btnDelete, Mode=OneWay, Source={StaticResource Resources}}" Width="100" Margin="5" Height="30" IsEnabled="False" Click="btnDelete_Click" />
                  <Button x:Name="btnCancel" Content="{Binding Path=btnCancel, Mode=OneWay, Source={StaticResource Resources}}" Width="100" Margin="5" Height="30" IsEnabled="False" Click="btnCancel_Click" />
               </StackPanel>
               <StackPanel>
                  <Button x:Name="btnRefresh" Content="{Binding Path=btnRefresh, Mode=OneWay, Source={StaticResource Resources}}" Width="100" Margin="5" Height="30" IsEnabled="True" Click="btnRefresh_Click" />
               </StackPanel>
               <!--<StackPanel Orientation="Vertical">
                        <Label  Content="     " />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"  DataContext="{StaticResource LimitViewSource}">
                    <StackPanel Orientation="Vertical">
                        <Label x:Name="lblGeneral"  Content="{Binding Path=General, Mode=OneWay, Source={StaticResource Resources}}" FontSize="22" FontWeight="Bold" />
                        <Label x:Name="lblPlastification"  Content="{Binding Plastification, Mode=OneWay, Source={StaticResource Resources}}" Width="84" />
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                        <Label  Content="     " />
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                        <Label x:Name="lblGeneral1"  Content="{Binding Path=A, Mode=OneWay, Source={StaticResource Resources}}" FontSize="22" FontWeight="Bold" Height="39" />
                        <TextBox Margin="10,3,0,0" x:Name="txtPlastification" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding Value, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                        <Label  Content="     " />
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                        <Button x:Name="btnSavePlast" Content="{Binding Path=btnSave, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnSavePlast_Click" />
                        <Button x:Name="btnEditPlast" Content="{Binding Path=btnEdit, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnEditPlast_Click" />
                        <Button x:Name="btnCancelPlast" Content="{Binding Path=btnCancel, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnCancelPlast_Click" />
                    </StackPanel>
                    </StackPanel>-->
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1"  Margin="10" ShowGridLines="false" IsEnabled="True" Background="{x:Null}" DataContext="{StaticResource PreSettingsDataViewSource}" >
            <Custom:XamDataGrid x:Name="gridPresettings" DataSource="{Binding}" Background="White" SelectedItemsChanged="gridPresettings_SelectedItemsChanged" Width="Auto">
                    <Custom:XamDataGrid.ViewSettings>
                        <Custom:GridViewSettings/>
                    </Custom:XamDataGrid.ViewSettings>
                    <Custom:XamDataGrid.FieldLayoutSettings>
                        <Custom:FieldLayoutSettings AutoGenerateFields="False" HeaderPrefixAreaDisplayMode="FieldChooserButton"/>
                    </Custom:XamDataGrid.FieldLayoutSettings>
                    <Custom:XamDataGrid.FieldLayouts>
                        <Custom:FieldLayout >
                            <Custom:FieldLayout.Settings>
                                <Custom:FieldLayoutSettings/>
                            </Custom:FieldLayout.Settings>
                            <Custom:Field Name="MaterialID" Label="{Binding Path=lblSteelgrade, Mode=OneWay, Source={StaticResource Resources}}" Width="*" >
                                <Custom:Field.Settings>
                                    <Custom:FieldSettings AllowEdit="False" AllowRecordFiltering="True"/>
                                </Custom:Field.Settings>
                            </Custom:Field>
                     <Custom:Field Name="CassetteNo" Label="{Binding Path=lblCassetteNo, Mode=OneWay, Source={StaticResource Resources}}" Width="*" >
                                <Custom:Field.Settings>
                                    <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True"/>
                                </Custom:Field.Settings>
                            </Custom:Field>
                     <Custom:Field Name="StartRangeThickness" Label="{Binding Path=lblStartRangeThickness, Mode=OneWay, Source={StaticResource Resources}}" Width="*" >
                                <Custom:Field.Settings>
                                    <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True" />
                                </Custom:Field.Settings>
                            </Custom:Field>
                     <Custom:Field Name="EndRangeThickness" Label="{Binding Path=lblEndRangeThickness, Mode=OneWay, Source={StaticResource Resources}}" Width="*">
                                <Custom:Field.Settings>
                                    <Custom:FieldSettings AllowEdit="False" AllowRecordFiltering="True" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" >
                                    </Custom:FieldSettings>
                                </Custom:Field.Settings>
                            </Custom:Field>
                     <Custom:Field Name="StartRangeWidth" Label="{Binding Path=lblStartRangeWidth, Mode=OneWay, Source={StaticResource Resources}}"  Width="*">
                                <Custom:Field.Settings>
                                    <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True" />
                                </Custom:Field.Settings>
                            </Custom:Field>
                     <Custom:Field Name="EndRangeWidth" Label="{Binding Path=lblEndRangeWidth, Mode=OneWay, Source={StaticResource Resources}}"  Width="*">
                                <Custom:Field.Settings>
                                    <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True" />
                                </Custom:Field.Settings>
                            </Custom:Field>
                     <Custom:Field Name="CorrPlastification" Label="{Binding Path=lblCorrPlastification, Mode=OneWay, Source={StaticResource Resources}}" Width="*">
                                <Custom:Field.Settings>
                                    <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True" />
                                </Custom:Field.Settings>
                            </Custom:Field>
                     <Custom:Field Name="CenterHeightBending" Label="{Binding Path=lblCenterHeightBending, Mode=OneWay, Source={StaticResource Resources}}" Width="*">
                                <Custom:Field.Settings>
                                    <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True" />
                                </Custom:Field.Settings>
                            </Custom:Field>
                     <Custom:Field Name="CurveProfile" Label="{Binding Path=lblCurveProfile, Mode=OneWay, Source={StaticResource Resources}}" Width="*">
                                <Custom:Field.Settings>
                                    <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True" />
                                </Custom:Field.Settings>
                            </Custom:Field>
                     <Custom:Field Name="TiltingLeft" Label="{Binding Path=lblTiltLeft, Mode=OneWay, Source={StaticResource Resources}}" Width="*">
                                <Custom:Field.Settings>
                                    <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True" />
                                </Custom:Field.Settings>
                            </Custom:Field>
                     <Custom:Field Name="TiltingRight" Label="{Binding Path=lblTiltRight, Mode=OneWay, Source={StaticResource Resources}}" Width="*">
                                <Custom:Field.Settings>
                                    <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True" />
                                </Custom:Field.Settings>
                            </Custom:Field>
                     <Custom:Field Name="Enable" Label="{Binding Path=Enable, Mode=OneWay, Source={StaticResource Resources}}" Width="*">
                                <Custom:Field.Settings>
                                    <Custom:FieldSettings AllowEdit="False" AllowRecordFiltering="True" EditorType="{x:Type igEditors:XamCheckEditor}" />
                                </Custom:Field.Settings>
                            </Custom:Field>
                        </Custom:FieldLayout>
                    </Custom:XamDataGrid.FieldLayouts>
                </Custom:XamDataGrid>
            </Grid>
        </Grid>
    </Grid>
</Page>
