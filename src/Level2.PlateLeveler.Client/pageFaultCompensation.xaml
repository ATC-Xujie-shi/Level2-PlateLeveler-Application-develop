<Page x:Class="Level2.PlateLeveler.Client.pageFaultCompensation"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:ig="http://schemas.infragistics.com/xaml" 
    xmlns:Custom="http://infragistics.com/DataPresenter"
    xmlns:my="clr-namespace:Level2.PlateLeveler.Client"
    xmlns:igEditors="http://infragistics.com/Editors"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:type="clr-namespace:Level2.PlateLeveler.DataTypes;assembly=Level2.PlateLeveler.DataTypes"
	x:Name="pageFC"
    mc:Ignorable="d" 
    d:DesignHeight="1000" d:DesignWidth="1920" >

    <Page.Resources>
        <CollectionViewSource x:Name="FCSource" x:Key="FCDataViewSource" d:DesignSource="{d:DesignInstance {x:Type type:FaultCompensation}, CreateList=True}"/>
        <CollectionViewSource x:Key="FCControlDataViewSource" d:DesignSource="{d:DesignInstance {x:Type type:FaultCompensation}, CreateList=True}"/>
        <!--<CollectionViewSource x:Key="PriorityDataViewSource" d:DesignSource="{d:DesignInstance {x:Type type:PrioritiesAttribute}, CreateList=True}"/>-->
        <!--No PrioritiesAttribute ,So Delete the type:PrioritiesAttribute-->
        <CollectionViewSource x:Key="PriorityDataViewSource" d:DesignSource="{}, CreateList=True}"/>
    </Page.Resources>
    <Page.Background>
        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#FF2177BF" Offset="0.007"/>
            <GradientStop Color="White" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>
    <Grid Visibility="Visible" ShowGridLines="false"  DataContext="{StaticResource FCControlDataViewSource}">
        <Grid ShowGridLines="false" Margin="8,8,8,0" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid  Margin="10,10,10,0"  Grid.Row="0" ShowGridLines="false" IsEnabled="True" Background="{x:Null}">
                <StackPanel Orientation="Horizontal" Background="{x:Null}" Margin="0,10,0,0" >
                    <StackPanel Orientation="Vertical">
                        <Label x:Name="lblCassetteNo" Content="{Binding Path=lblCassetteNo, Mode=OneWay, Source={StaticResource Resources}}"/>
                        <Label x:Name="lblMaxSki" Content="{Binding Path=lblMaxSki, Mode=OneWay, Source={StaticResource Resources}}"/>
                        <Label x:Name="lblEvaluationSki" Content="{Binding Path=lblEvaluationSki, Mode=OneWay, Source={StaticResource Resources}}"/>
                        <Label x:Name="lblMaxHeightEdgeWave" Content="{Binding Path=lblMaxHeightEdgeWave, Mode=OneWay, Source={StaticResource Resources}}"/>
                        <Label x:Name="lblEvaluationEdgeWave" Content="{Binding Path=lblEvaluationEdgeWave, Mode=OneWay, Source={StaticResource Resources}}"/>
                        <Label x:Name="lblMaxHeightCenterWave" Content="{Binding Path=lblMaxHeightCenterWave, Mode=OneWay, Source={StaticResource Resources}}"/>
                        <Label x:Name="lblEvaluationCenterWave" Content="{Binding Path=lblEvaluationCenterWave, Mode=OneWay, Source={StaticResource Resources}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                        <TextBox Margin="10,3,0,0" x:Name="txtCassetteNo" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding CassetteNo, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                        <TextBox Margin="10,3,0,0" x:Name="txtMaxSki" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MaxSki, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                        <TextBox Margin="10,3,0,0" x:Name="txtEvaluationSki" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding EvaluationSki, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                        <TextBox Margin="10,3,0,0" x:Name="txtMaxHeightEdgeWave" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MaxHeightEdgeWave, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                        <TextBox Margin="10,3,0,0" x:Name="txtEvaluationEdgeWave" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding EvaluationEdgeWave, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                        <TextBox Margin="10,3,0,0" x:Name="txtMaxHeightCenterWave" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MaxHeightCenterWave, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                        <TextBox Margin="10,3,0,0" x:Name="txtEvaluationCenterWave" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding EvaluationCenterWave, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                   </StackPanel>

                    <StackPanel Orientation="Vertical">
                        <Label  Content="     " />
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                        <Label x:Name="lblMaxTilting" Content="{Binding Path=lblMaxTilting, Mode=OneWay, Source={StaticResource Resources}}"/>
                        <Label x:Name="lblEvaluationTilting" Content="{Binding Path=lblEvaluationTilting, Mode=OneWay, Source={StaticResource Resources}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                        <TextBox Margin="10,3,0,0" x:Name="txtMaxTilting" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MaxTilting, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                        <TextBox Margin="10,3,0,0" x:Name="txtEvaluationTilting" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding EvaluationTilting, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                        <Label  Content="     " />
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                        <Button x:Name="btnCopy" Content="{Binding Path=btnCopy, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnCopy_Click" />
                        <Button x:Name="btnCreate" Content="{Binding Path=btnCreate, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" Click="btnCreate_Click"/>
                        <Button x:Name="btnSave" Content="{Binding Path=btnSave, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnSave_Click"/>
                        <Button x:Name="btnEdit" Content="{Binding Path=btnEdit, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnEdit_Click"/>
                        <Button x:Name="btnDelete" Content="{Binding Path=btnDelete, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnDelete_Click" />
                        <Button x:Name="btnCancel" Content="{Binding Path=btnCancel, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnCancel_Click" />
                    </StackPanel>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1" Margin="10,10,10,0" ShowGridLines="false" IsEnabled="True" Background="{x:Null}" >
                <StackPanel Orientation="Horizontal">
                    <Grid DataContext="{StaticResource FCDataViewSource}" >
                        <StackPanel Orientation="Vertical">
                            <Label Content="{Binding Path=FaultCompensation, Mode=OneWay, Source={StaticResource Resources}}" FontWeight="Bold" />
                            <Custom:XamDataGrid x:Name="gridFC" DataSource="{Binding}" Background="DeepSkyBlue"  Width="Auto" SelectedItemsChanged="gridFC_SelectedItemsChanged">
                        <Custom:XamDataGrid.ViewSettings>
                            <Custom:GridViewSettings/>
                        </Custom:XamDataGrid.ViewSettings>
                        <Custom:XamDataGrid.FieldLayoutSettings>
                            <Custom:FieldLayoutSettings AutoGenerateFields="False" HeaderPrefixAreaDisplayMode="FieldChooserButton"/>
                        </Custom:XamDataGrid.FieldLayoutSettings>
                        <Custom:XamDataGrid.FieldLayouts>
                            <Custom:FieldLayout >
                                <Custom:FieldLayout.Settings>
                                    <Custom:FieldLayoutSettings/>
                                </Custom:FieldLayout.Settings>
                                        <Custom:Field Name="CassetteNo" Label="{Binding Path=lblCassetteNo, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto" >
                                    <Custom:Field.Settings>
                                        <Custom:FieldSettings AllowEdit="False" AllowRecordFiltering="True"/>
                                    </Custom:Field.Settings>
                                </Custom:Field>
                                        <Custom:Field Name="MaxHeightEdgeWave" Label="{Binding Path=lblMaxHeightEdgeWave, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto" >
                                    <Custom:Field.Settings>
                                                <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True"/>
                                    </Custom:Field.Settings>
                                </Custom:Field>
                                        <Custom:Field Name="EvaluationEdgeWave" Label="{Binding Path=lblEvaluationEdgeWave, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto" >
                                    <Custom:Field.Settings>
                                                <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True"/>
                                    </Custom:Field.Settings>
                                </Custom:Field>
                                        <Custom:Field Name="EvaluationTilting" Label="{Binding Path=lblEvaluationTilting, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                    <Custom:Field.Settings>
                                                <Custom:FieldSettings AllowEdit="False" AllowRecordFiltering="True" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" >
                                        </Custom:FieldSettings>
                                    </Custom:Field.Settings>
                                </Custom:Field>
                                        <Custom:Field Name="MaxHeightCenterWave" Label="{Binding Path=lblMaxHeightCenterWave, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                    <Custom:Field.Settings>
                                                <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True" />
                                    </Custom:Field.Settings>
                                </Custom:Field>
                                        <Custom:Field Name="EvaluationCenterWave" Label="{Binding Path=lblEvaluationCenterWave, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                    <Custom:Field.Settings>
                                        <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True" />
                                    </Custom:Field.Settings>
                                </Custom:Field>
                                        <Custom:Field Name="MaxSki" Label="{Binding Path=lblMaxSki, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                    <Custom:Field.Settings>
                                                <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True" />
                                    </Custom:Field.Settings>
                                </Custom:Field>
                                        <Custom:Field Name="EvaluationSki" Label="{Binding Path=lblEvaluationSki, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                    <Custom:Field.Settings>
                                                <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True" />
                                    </Custom:Field.Settings>
                                </Custom:Field>
                                        <Custom:Field Name="MaxTilting" Label="{Binding Path=lblMaxTilting, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                    <Custom:Field.Settings>
                                                <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True" />
                                    </Custom:Field.Settings>
                                </Custom:Field>
                            </Custom:FieldLayout>
                        </Custom:XamDataGrid.FieldLayouts>
                    </Custom:XamDataGrid>
                    </StackPanel>
                    </Grid>
                    <StackPanel Orientation="Vertical">
                        <Label  Content="     " />
                    </StackPanel>
                    <Grid DataContext="{StaticResource PriorityDataViewSource}" Width="175">
                    <StackPanel Orientation="Vertical">
                            <Label Content="{Binding Path=Priorities, Mode=OneWay, Source={StaticResource Resources}}" FontWeight="Bold"/>
                            <Custom:XamDataGrid x:Name="gridPriority" DataSource="{Binding}" Background="DeepSkyBlue"  Width="Auto">
                        <Custom:XamDataGrid.ViewSettings>
                            <Custom:GridViewSettings/>
                        </Custom:XamDataGrid.ViewSettings>
                        <Custom:XamDataGrid.FieldLayoutSettings>
                            <Custom:FieldLayoutSettings AutoGenerateFields="False" HeaderPrefixAreaDisplayMode="FieldChooserButton"/>
                        </Custom:XamDataGrid.FieldLayoutSettings>
                        <Custom:XamDataGrid.FieldLayouts>
                            <Custom:FieldLayout >
                                <Custom:FieldLayout.Settings>
                                    <Custom:FieldLayoutSettings/>
                                </Custom:FieldLayout.Settings>
                                        <Custom:Field Name="Priority" Label="{Binding Path=Priority, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto" >
                                    <Custom:Field.Settings>
                                                <Custom:FieldSettings AllowEdit="False" AllowRecordFiltering="True" />
                                    </Custom:Field.Settings>
                                </Custom:Field>
                                        <Custom:Field Name="PriorityID" Label="{Binding Path=PriorityID, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto" >
                                    <Custom:Field.Settings>
                                                <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True"/>
                                    </Custom:Field.Settings>
                                </Custom:Field>
                            </Custom:FieldLayout>
                        </Custom:XamDataGrid.FieldLayouts>
                    </Custom:XamDataGrid>
                    </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
         <!--<DataGrid Name="dataGridFaultCompensation" HorizontalAlignment="Left" Height="Auto" Margin="10,12,0,-405" Grid.Row="2" VerticalAlignment="Top" Width="Auto">
            <DataGrid.Columns>
               <DataGridTextColumn Header="Cssete No" Binding="{Binding CassetteNo, Mode=OneWay}" />
               <DataGridTextColumn Header="Max Height Edge Wave" Binding="{Binding MaxHeightEdgeWave, Mode=OneWay}" />
               <DataGridTextColumn Header="Evaluation Edge Wave" Binding="{Binding EvaluationEdgeWave, Mode=OneWay}" />
               <DataGridTextColumn Header="Evaluation Tilting" Binding="{Binding EvaluationTilting, Mode=OneWay}" />
               <DataGridTextColumn Header="Max Height Center Wave" Binding="{Binding MaxHeightCenterWave, Mode=OneWay}" />
               <DataGridTextColumn Header="Max Ski" Binding="{Binding MaxSki, Mode=OneWay}" />
            </DataGrid.Columns>
         </DataGrid>-->
      </Grid>
    </Grid>
</Page>
