<Page x:Class="Level2.PlateLeveler.Client.pageTemperature"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:ig="http://schemas.infragistics.com/xaml" 
    xmlns:Custom="http://infragistics.com/DataPresenter"
    xmlns:my="clr-namespace:Level2.PlateLeveler.Client"
    xmlns:igEditors="http://infragistics.com/Editors"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:type="clr-namespace:Level2.PlateLeveler.DataTypes;assembly=Level2.PlateLeveler.DataTypes"
	x:Name="pageTemp"
    mc:Ignorable="d" 
    d:DesignHeight="1000" d:DesignWidth="1920" >

    <Page.Resources>
        <CollectionViewSource x:Name="TemperatureSource" x:Key="TemperatureDataViewSource" d:DesignSource="{d:DesignInstance {x:Type type:Temp}, CreateList=True}"/>
        <CollectionViewSource x:Key="TemperatureControlDataViewSource" d:DesignSource="{d:DesignInstance {x:Type type:Temp}, CreateList=True}"/>
        <CollectionViewSource x:Name="SteelgradeSource" x:Key="SteelgradeDataViewSource" d:DesignSource="{d:DesignInstance {x:Type type:Steelgrade}, CreateList=True}"/>
        <CollectionViewSource  x:Key="SteelgradeControlDataViewSource" d:DesignSource="{d:DesignInstance {x:Type type:Steelgrade}, CreateList=True}"/>
    </Page.Resources>
    <Page.Background>
        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#FF2177BF" Offset="0.007"/>
            <GradientStop Color="White" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>
    <Grid  Visibility="Visible" ShowGridLines="false"  DataContext="{StaticResource TemperatureControlDataViewSource}">
        <Grid ShowGridLines="false" Margin="8,8,8,0" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid  Margin="10,10,10,0"  Grid.Row="0" ShowGridLines="false" IsEnabled="True" Background="{x:Null}">
                <StackPanel Orientation="Horizontal" Background="{x:Null}" Margin="0,10,0,0" >
                    <StackPanel Orientation="Vertical">
                        <Label x:Name="lblTemperature" Content="{Binding Path=Temperature, Mode=OneWay, Source={StaticResource Resources}}"/>
                        <Label x:Name="lblYieldPoint" Content="{Binding Path=lblYieldPoint, Mode=OneWay, Source={StaticResource Resources}}"/>
                        <Label x:Name="lblEModule" Content="{Binding Path=lblEModule, Mode=OneWay, Source={StaticResource Resources}}"/>
                        <Label x:Name="lblSteelgrade" Content="{Binding Path=lblSteelgrade, Mode=OneWay, Source={StaticResource Resources}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                        <TextBox Margin="10,3,0,0" x:Name="txtTemperature" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding Temperature, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                        <TextBox Margin="10,3,0,0" x:Name="txtYieldPoint" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding YieldPoint, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                        <TextBox Margin="10,3,0,0" x:Name="txtEModule" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding EModule, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                        <ComboBox Margin="10,3,0,0" x:Name="cboSteelgrade" SelectedValue="{Binding Steelgrade, Mode=OneWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" ItemsSource="{Binding Steelgrade}" DisplayMemberPath="SteelGrade" SelectedValuePath="SteelGrade"  IsEnabled="True" SelectionChanged="cboSteelgrade_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                        <Label  Content="     " />
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                        <Button x:Name="btnCreate" Content="{Binding Path=btnCreate, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" Click="btnCreate_Click" />
                        <Button x:Name="btnSave" Content="{Binding Path=btnSave, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnSave_Click" />
                        <Button x:Name="btnEdit" Content="{Binding Path=btnEdit, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnEdit_Click" />
                        <Button x:Name="btnDelete" Content="{Binding Path=btnDelete, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnDelete_Click" />
                        <Button x:Name="btnCancel" Content="{Binding Path=btnCancel, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnCancel_Click" />
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Width="342">
                        <Label  Content="     " />
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                        <Label x:Name="lblSteelgradeSG" Content="{Binding Path=lblSteelgrade, Mode=OneWay, Source={StaticResource Resources}}"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical"  DataContext="{StaticResource SteelgradeControlDataViewSource}">
                        <TextBox Margin="10,3,0,0" x:Name="txtSteelgrade" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding SteelGrade, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                        <Button x:Name="btnCreateSG" Content="{Binding Path=btnCreate, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" Click="btnCreateSG_Click" />
                        <Button x:Name="btnSaveSG" Content="{Binding Path=btnSave, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnSaveSG_Click" />
                        <Button x:Name="btnEditSG" Content="{Binding Path=btnEdit, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnEditSG_Click" />
                        <Button x:Name="btnDeleteSG" Content="{Binding Path=btnDelete, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnDeleteSG_Click" />
                        <Button x:Name="btnCancelSG" Content="{Binding Path=btnCancel, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnCancelSG_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1"  Margin="10,10,10,0" ShowGridLines="false" IsEnabled="True" Background="{x:Null}" DataContext="{StaticResource TemperatureDataViewSource}" >
                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Vertical">
                        <Custom:XamDataGrid x:Name="gridTemperature" DataSource="{Binding}" Background="DeepSkyBlue"  Width="Auto" SelectedItemsChanged="gridTemperature_SelectedItemsChanged" >
                        <Custom:XamDataGrid.ViewSettings>
                            <Custom:GridViewSettings/>
                        </Custom:XamDataGrid.ViewSettings>
                        <Custom:XamDataGrid.FieldLayoutSettings>
                            <Custom:FieldLayoutSettings AutoGenerateFields="False" HeaderPrefixAreaDisplayMode="FieldChooserButton"/>
                        </Custom:XamDataGrid.FieldLayoutSettings>
                        <Custom:XamDataGrid.FieldLayouts>
                            <Custom:FieldLayout >
                                <Custom:FieldLayout.Settings>
                                    <Custom:FieldLayoutSettings/>
                                </Custom:FieldLayout.Settings>
                                    <Custom:Field Name="Temperature" Label="{Binding Path=Temperature, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto" >
                                    <Custom:Field.Settings>
                                        <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True"/>
                                    </Custom:Field.Settings>
                                </Custom:Field>
                                    <Custom:Field Name="YieldPoint" Label="{Binding Path=lblYieldPoint, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto" >
                                    <Custom:Field.Settings>
                                        <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True"/>
                                    </Custom:Field.Settings>
                                </Custom:Field>
                                    <Custom:Field Name="EModule" Label="{Binding Path=lblEModule, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto" >
                                    <Custom:Field.Settings>
                                        <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True"/>
                                    </Custom:Field.Settings>
                                </Custom:Field>
                            </Custom:FieldLayout>
                        </Custom:XamDataGrid.FieldLayouts>
                    </Custom:XamDataGrid>
                </StackPanel>
                <StackPanel Orientation="Vertical" Width="342">
                    <Label  Content="  " />
                </StackPanel>
                    <StackPanel Orientation="Vertical"  DataContext="{StaticResource SteelgradeDataViewSource}">
                        <Custom:XamDataGrid x:Name="gridSteelgrade" DataSource="{Binding}" Background="DeepSkyBlue"  Width="99" Height="Auto" SelectedItemsChanged="gridSteelgrade_SelectedItemsChanged"  >
                            <Custom:XamDataGrid.ViewSettings>
                                <Custom:GridViewSettings/>
                            </Custom:XamDataGrid.ViewSettings>
                            <Custom:XamDataGrid.FieldLayoutSettings>
                                <Custom:FieldLayoutSettings AutoGenerateFields="False" HeaderPrefixAreaDisplayMode="FieldChooserButton"/>
                            </Custom:XamDataGrid.FieldLayoutSettings>
                            <Custom:XamDataGrid.FieldLayouts>
                                <Custom:FieldLayout >
                                    <Custom:FieldLayout.Settings>
                                        <Custom:FieldLayoutSettings/>
                                    </Custom:FieldLayout.Settings>
                                    <Custom:Field Name="SteelGrade" Label="{Binding Path=lblSteelGrade, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto" >
                                        <Custom:Field.Settings>
                                            <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True"/>
                                        </Custom:Field.Settings>
                                    </Custom:Field>

                                </Custom:FieldLayout>
                            </Custom:XamDataGrid.FieldLayouts>
                        </Custom:XamDataGrid>
                    </StackPanel>
               </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
