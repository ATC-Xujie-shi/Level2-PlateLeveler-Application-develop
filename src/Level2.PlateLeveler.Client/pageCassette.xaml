<Page x:Class="Level2.PlateLeveler.Client.pageCassette"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ig="http://schemas.infragistics.com/xaml"
    xmlns:Custom="http://infragistics.com/DataPresenter"
    xmlns:my="clr-namespace:Level2.PlateLeveler.Client"
    xmlns:igEditors="http://infragistics.com/Editors"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:type="clr-namespace:Level2.PlateLeveler.DataTypes;assembly=Level2.PlateLeveler.DataTypes"
	x:Name="pageCassettes"
    mc:Ignorable="d"
    d:DesignHeight="1000" d:DesignWidth="1920" >

    <Page.Resources>
        <CollectionViewSource x:Name="CassetteSource" x:Key="CassetteDataViewSource" d:DesignSource="{d:DesignInstance {x:Type type:Cassette}, CreateList=True}"/>
        <CollectionViewSource x:Key="CassetteControlDataViewSource" d:DesignSource="{d:DesignInstance {x:Type type:Cassette}, CreateList=True}"/>
    </Page.Resources>
    <Page.Background>
        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="White" Offset="0.007"/>
            <GradientStop Color="White" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>
    <Grid Visibility="Visible" ShowGridLines="false"  DataContext="{StaticResource CassetteControlDataViewSource}">
        <Grid ShowGridLines="false" Margin="8,8,8,0" >
            <Grid.RowDefinitions>
                <RowDefinition Height="150"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="10"/>
            </Grid.RowDefinitions>
            <Grid  Margin="10"  Grid.Row="0" ShowGridLines="false" IsEnabled="True" Background="{x:Null}">
                <StackPanel Orientation="Horizontal" Background="{x:Null}">
                    <StackPanel Orientation="Vertical">
                  <Label x:Name="lblNoOfRolls" Content="{Binding Path=lblNoOfRolls, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                  <Label x:Name="lblBearingDiameter" Content="{Binding Path=lblBearingDiameter, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                  <Label x:Name="lblRollDiameter" Content="{Binding Path=lblRollDiameter, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                  <Label x:Name="lblPitchOfRolls" Content="{Binding Path=lblPitchOfRolls, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                  <TextBox Height="30" Margin="1" x:Name="txtNoOfRolls" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding NoOfRolls, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Height="30" Margin="1" x:Name="txtBearingDiameter" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding BearingDiameter, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Height="30" Margin="1" x:Name="txtRollDiameter" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding RollDiameter, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Height="30" Margin="1" x:Name="txtPitchOfRolls" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding PitchOfRolls, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                </StackPanel>

                    <StackPanel Orientation="Vertical" Width="20">
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                  <Label x:Name="lblDistanceA" Content="{Binding Path=lblDistanceA, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                  <Label x:Name="lblDistanceB" Content="{Binding Path=lblDistanceB, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                  <Label x:Name="lblDistanceC" Content="{Binding Path=lblDistanceC, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                  <Label x:Name="lblMaxMotorPower"  Content="{Binding Path=lblMaxMotorPower, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
               </StackPanel>

               <StackPanel Orientation="Vertical">
                  <TextBox Height="30" Margin="1" x:Name="txtDistanceA" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding DistanceA, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Height="30" Margin="1" x:Name="txtDistanceB" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding DistanceB, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Height="30" Margin="1" x:Name="txtDistanceC" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding DistanceC, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Height="30" Margin="1" x:Name="txtMaxMotorPower" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MaxMotorPower, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
               </StackPanel>

                    <StackPanel Orientation="Vertical" Width="20">
                    </StackPanel>
               <StackPanel Orientation="Vertical">
                  <Label x:Name="lblMaxMotorTorque"   Content="{Binding Path=lblMaxMotorTorque, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                  <Label x:Name="lblMinThicknessPlate"   Content="{Binding Path=lblMinThicknessPlate, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                  <Label x:Name="lblMaxThicknessPlate"  Content="{Binding Path=lblMaxThicknessPlate, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                  <Label x:Name="lblMaxAdjustment"  Content="{Binding Path=lblMaxAdjustment, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
               </StackPanel>
               <StackPanel Orientation="Vertical">
                  <TextBox Height="30" Margin="1" x:Name="txtMaxMotorTorque" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MaxMotorTorque, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Height="30" Margin="1" x:Name="txtMinThicknessPlate" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MinThicknessPlate, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Height="30" Margin="1" x:Name="txtMaxThicknessPlate" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MaxThicknessPlate, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False" TextChanged="txtMaxThicknessPlate_TextChanged" KeyDown="txtMaxThicknessPlate_KeyDown"/>
                  <TextBox Height="30" Margin="1" x:Name="txtMaxAdjustment" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MaxAdjustment, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
               </StackPanel>
               <StackPanel Orientation="Vertical" Width="20">
               </StackPanel>
               <StackPanel Orientation="Vertical">
                  <Label x:Name="lblMaxLevelingPressure"  Content="{Binding Path=lblMaxLevelingPressure, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                  <Label x:Name="lblMaxCenterHeightBending"  Content="{Binding Path=lblMaxCenterHeightBending, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                  <Label x:Name="lblMinCenterHeightBending"  Content="{Binding Path=lblMinCenterHeightBending, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                  <Label x:Name="lblMaxCrossTiltLeft"  Content="{Binding Path=lblMaxCrossTiltLeft, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
               </StackPanel>
               <StackPanel Orientation="Vertical">
                  <TextBox Height="30" Margin="1" x:Name="txtMaxLevelingPressure" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MaxLevelingPressure, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Height="30" Margin="1" x:Name="txtMaxCenterHeightBending" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MaxCenterHeightBending, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Height="30" Margin="1" x:Name="txtMinCenterHeightBending" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MinCenterHeightBending, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Height="30" Margin="1" x:Name="txtMaxCrossTiltLeft" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MaxCrossTiltLeft, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
               </StackPanel>
               <StackPanel Width="20"></StackPanel>
                  <StackPanel Orientation="Vertical">
                  <Label x:Name="lblMinCrossTiltLeft"  Content="{Binding Path=lblMinCrossTiltLeft, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                  <Label x:Name="lblMaxCrossTiltRight"  Content="{Binding Path=lblMaxCrossTiltRight, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                  <Label x:Name="lblMinCrossTiltRight"  Content="{Binding Path=lblMinCrossTiltRight, Mode=OneWay, Source={StaticResource Resources}}" Height="30" Margin="1"/>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Orientation="Vertical">
                                <TextBlock Text="{Binding Path=Active, Mode=OneWay, Source={StaticResource Resources}}" Margin="5,4,0,0" HorizontalAlignment="Left" />
                            </StackPanel>
                            <StackPanel Orientation="Vertical">
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Vertical">
                  <TextBox Height="30" Margin="1" x:Name="txtMinCrossTiltLeft" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MinCrossTiltLeft, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Height="30" Margin="1" x:Name="txtMaxCrossTiltRight" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MaxCrossTiltRight, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <TextBox Height="30" Margin="1" x:Name="txtMinCrossTiltRight" Style="{DynamicResource AndritzTextBoxStyle}" Text="{Binding MinCrossTiltRight, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False"/>
                  <CheckBox x:Name="chkActive" Margin="1 10" IsChecked="{Binding Active, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}" IsEnabled="False" />
               </StackPanel>
                    <StackPanel Orientation="Vertical" Width="50">
                    </StackPanel>
               <StackPanel Orientation="Vertical">
                  <Button x:Name="btnCreate" Content="{Binding Path=btnCreate, Mode=OneWay, Source={StaticResource Resources}}" Width="100" Margin="5" Height="30" Click="btnCreate_Click"/>
                  <Button x:Name="btnEdit" Content="{Binding Path=btnEdit, Mode=OneWay, Source={StaticResource Resources}}" Width="100" Margin="5" Height="30" IsEnabled="False" Click="btnEdit_Click"/>
                  <Button x:Name="btnSave" Content="{Binding Path=btnSave, Mode=OneWay, Source={StaticResource Resources}}" Width="100" Margin="5" Height="30" IsEnabled="False" Click="btnSave_Click"/>
               </StackPanel>
               <StackPanel Orientation="Vertical">
                  <Button x:Name="btnCopy" Content="{Binding Path=btnCopy, Mode=OneWay, Source={StaticResource Resources}}" Width="100" Margin="5" Height="30" IsEnabled="False" Click="btnCopy_Click" />
                  <Button x:Name="btnDelete" Content="{Binding Path=btnDelete, Mode=OneWay, Source={StaticResource Resources}}" Width="100" Margin="5" Height="30" IsEnabled="False" Click="btnDelete_Click"/>
                  <Button x:Name="btnCancel" Content="{Binding Path=btnCancel, Mode=OneWay, Source={StaticResource Resources}}" Width="100" Margin="5" Height="30" IsEnabled="False" Click="btnCancel_Click"/>
               </StackPanel>
               <!--<StackPanel Orientation="Vertical">
                        <Button x:Name="btnCopy" Content="{Binding Path=btnCopy, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnCopy_Click" />
                        <Button x:Name="btnCreate" Content="{Binding Path=btnCreate, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" Click="btnCreate_Click"/>
                        <Button x:Name="btnSave" Content="{Binding Path=btnSave, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnSave_Click"/>
                        <Button x:Name="btnEdit" Content="{Binding Path=btnEdit, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnEdit_Click"/>
                        <Button x:Name="btnDelete" Content="{Binding Path=btnDelete, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnDelete_Click"/>
                        <Button x:Name="btnCancel" Content="{Binding Path=btnCancel, Mode=OneWay, Source={StaticResource Resources}}" Margin="10,5,0,0" Height="26" Width="107" IsEnabled="False" Click="btnCancel_Click"/>
                    </StackPanel>-->
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1"  Margin="10,10,10,0" ShowGridLines="false" IsEnabled="True" Background="{x:Null}" DataContext="{StaticResource CassetteDataViewSource}" >
            <Custom:XamDataGrid x:Name="gridCassette" DataSource="{Binding}" Background="White"  SelectedItemsChanged="gridCassette_SelectedItemsChanged">
                            <Custom:XamDataGrid.ViewSettings>
                                <Custom:GridViewSettings/>
                            </Custom:XamDataGrid.ViewSettings>
                            <Custom:XamDataGrid.FieldLayoutSettings>
                                <Custom:FieldLayoutSettings AutoGenerateFields="False" HeaderPrefixAreaDisplayMode="FieldChooserButton"/>
                            </Custom:XamDataGrid.FieldLayoutSettings>
                            <Custom:XamDataGrid.FieldLayouts>
                                <Custom:FieldLayout >
                                    <Custom:FieldLayout.Settings>
                                        <Custom:FieldLayoutSettings/>
                                    </Custom:FieldLayout.Settings>
                            <Custom:Field Name="CassetteNo" Label="{Binding Path=lblCassetteNo, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto" >
                                        <Custom:Field.Settings>
                                            <Custom:FieldSettings AllowEdit="False" AllowRecordFiltering="True"/>
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="NoOfRolls" Label="{Binding Path=lblNoOfRolls, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto" >
                                        <Custom:Field.Settings>
                                            <Custom:FieldSettings AllowEdit="False" AllowRecordFiltering="True"/>
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="BearingDiameter" Label="{Binding Path=lblBearingDiameter, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto" >
                                        <Custom:Field.Settings>
                                        <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True"/>
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="RollDiameter" Label="{Binding Path=lblRollDiameter, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto" >
                                        <Custom:Field.Settings>
                                        <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True"/>
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="PitchOfRolls" Label="{Binding Path=lblPitchOfRolls, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                            <Custom:FieldSettings AllowEdit="False" AllowRecordFiltering="True" EditorType="{x:Type igEditors:XamNumericEditor}" >
                                            </Custom:FieldSettings>
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="DistanceA"  Label="{Binding Path=lblDistanceA, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                            <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True" />
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="DistanceB"  Label="{Binding Path=lblDistanceB, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                            <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True" />
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="DistanceC" Label="{Binding Path=lblDistanceC, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                        <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True" />
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="MaxMotorPower" Label="{Binding Path=lblMaxMotorPower, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                            <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True" />
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="MaxMotorTorque" Label="{Binding Path=lblMaxMotorTorque, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                        <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True" />
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="MinThicknessPlate" Label="{Binding Path=lblMinThicknessPlate, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                        <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True" />
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="MaxThicknessPlate" Label="{Binding Path=lblMaxThicknessPlate, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                        <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True" />
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="MaxAdjustment" Label="{Binding Path=lblMaxAdjustment, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                        <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorDigit1Style}" AllowRecordFiltering="True" />
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="MaxLevelingPressure" Label="{Binding Path=lblMaxLevelingPressure, Mode=OneWay, Source={StaticResource Resources}}"  Width="Auto">
                                    <Custom:Field.Settings>
                                        <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True" />
                                    </Custom:Field.Settings>
                                </Custom:Field>
                            <Custom:Field Name="MaxCenterHeightBending" Label="{Binding Path=lblMaxCenterHeightBending, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                            <Custom:FieldSettings AllowEdit="False" AllowRecordFiltering="True" />
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="MinCenterHeightBending" Label="{Binding Path=lblMinCenterHeightBending, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                            <Custom:FieldSettings AllowEdit="False" AllowRecordFiltering="True" />
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="MaxCrossTiltLeft" Label="{Binding Path=lblMaxCrossTiltLeft, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                            <Custom:FieldSettings AllowEdit="False" AllowRecordFiltering="True" />
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="MinCrossTiltLeft" Label="{Binding Path=lblMinCrossTiltLeft, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                            <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True" />
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="MaxCrossTiltRight" Label="{Binding Path=lblMaxCrossTiltRight, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                            <Custom:FieldSettings AllowEdit="False" AllowRecordFiltering="True" />
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="MinCrossTiltRight" Label="{Binding Path=lblMinCrossTiltRight, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                            <Custom:FieldSettings AllowEdit="False" EditorStyle="{DynamicResource XamGridEditorStyle}" AllowRecordFiltering="True" />
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                            <Custom:Field Name="Active" Label="{Binding Path=Active, Mode=OneWay, Source={StaticResource Resources}}" Width="Auto">
                                        <Custom:Field.Settings>
                                            <Custom:FieldSettings AllowEdit="False" AllowRecordFiltering="True" EditorType="{x:Type igEditors:XamCheckEditor}" />
                                        </Custom:Field.Settings>
                                    </Custom:Field>
                                </Custom:FieldLayout>
                            </Custom:XamDataGrid.FieldLayouts>
                        </Custom:XamDataGrid>
                </Grid>
            <Grid Grid.Row="2"  Margin="10,10,10,0" ShowGridLines="false" IsEnabled="True" Background="{x:Null}" DataContext="{StaticResource CassetteDataViewSource}" >
                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Vertical"/>
                    <StackPanel Orientation="Vertical">
                        <TextBlock Margin="10,3,0,0" x:Name="txtActiveCassette" Width="34" FontSize="16" FontWeight="Bold" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
