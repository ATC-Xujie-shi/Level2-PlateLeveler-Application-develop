    <Style x:Key="XamGridEditorStyle" TargetType="{x:Type igEditors:XamNumericEditor}">
        <Setter Property="Format" Value="###,##0" />
        <Setter Property="ValueType" Value="{x:Type sys:Single}" />
        <Setter Property="Mask" Value="{}{double:-6.0}" />
    </Style>

    <Style x:Key="XamGridTimeEditorStyle" TargetType="{x:Type igEditors:XamDateTimeEditor}">
        <Setter Property="Format" Value="MM/dd/yy HH:mm:ss" />
        <Setter Property="ValueType" Value="{x:Type sys:DateTime}" />
        <Setter Property="Mask" Value="mm/dd/yy hh:mm:ss" />
    </Style>

    <Style x:Key="XamGridEditorDigit1Style" TargetType="{x:Type igEditors:XamNumericEditor}">
        <Setter Property="Format" Value="###,##0.0" />
        <Setter Property="ValueType" Value="{x:Type sys:Single}" />
        <Setter Property="Mask" Value="{}{double:-6.0}" />
    </Style>

    <Style x:Key="XamGridEditorDigit2Style" TargetType="{x:Type igEditors:XamNumericEditor}">
        <Setter Property="Format" Value="###,##0.00" />
        <Setter Property="ValueType" Value="{x:Type sys:Single}" />
        <Setter Property="Mask" Value="{}{double:-6.0}" />
    </Style>

    <Style x:Key="XamGridEditorDigit3Style" TargetType="{x:Type igEditors:XamNumericEditor}">
        <Setter Property="Format" Value="###,##0.000" />
        <Setter Property="ValueType" Value="{x:Type sys:Single}" />
        <Setter Property="Mask" Value="{}{double:-6.0}" />
    </Style>

    <Style x:Key="ButtonFocusVisual">
