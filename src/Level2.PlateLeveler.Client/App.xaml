<Application x:Class="Level2.PlateLeveler.Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:culture="clr-namespace:Level2.PlateLeveler.Client.Cultures"
             Startup="Application_Startup" >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
                <ResourceDictionary Source="Custom Styles.xaml"/>
                <ResourceDictionary Source="Simple Styles.xaml"/>
                <ResourceDictionary Source="LocalizationDictionary.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
